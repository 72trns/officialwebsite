    <!-- ==========================================
       3. 核心過場動畫 JavaScript
       ========================================== -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // 抓取所有含有 .scroll-fade 類別的網頁元素
            const fadeElements = document.querySelectorAll('.scroll-fade');

            // 建立環境偵測器
            const observerOptions = {
                root: null,         // 視窗（Viewport）作為偵測範圍
                rootMargin: "0px",  // 不做額外範圍外推
                threshold: 0.15     // 元素有 15% 進入畫面時，即觸發動畫
            };

            const appearanceObserver = new IntersectionObserver(function(entries, observer) {
                entries.forEach(entry => {
                    // 如果元素進入畫面
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible'); // 加上 Class 觸發 CSS 動畫
                        appearanceObserver.unobserve(entry.target); // 解除監聽（讓動畫只執行一次，保持乾淨）
                    }
                });
            }, observerOptions);

            // 將所有目標元素綁定偵測器
            fadeElements.forEach(element => {
                appearanceObserver.observe(element);
            });
        });
    </script>

